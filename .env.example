# Postgres connection string used by Prisma (CLI scripts and the Next.js app).
DATABASE_URL="postgresql://pearls:pearls@localhost:5432/pearls_migrator?schema=public"

# Public base URL used to build absolute links in robots.txt and sitemap.xml.
# Defaults to http://localhost:3000 when unset.
SITE_URL="http://localhost:3000"

# OpenAI access for `npm run metadata:ai`.
# Preferred from Russia: Amsterdam proxy (no local VPN).
# OPENAI_API_KEY here is PROXY_AUTH_TOKEN from openai-proxy shared/.env.
OPENAI_BASE_URL="https://spoken-word.info/openai-proxy/v1"
OPENAI_API_KEY=""

# Direct OpenAI fallback (requires VPN from Russia):
# OPENAI_BASE_URL=
# OPENAI_API_KEY="sk-..."

# Optional override for the external SOURCE_PERALS archive location.
# Defaults to the sibling ../SOURCE_PERALS repo when unset.
# PEARLS_SOURCE_ROOT="../SOURCE_PERALS"
