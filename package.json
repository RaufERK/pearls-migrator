{
  "name": "pearls-migrator",
  "version": "1.0.0",
  "description": "Word brochure to web catalog migrator for Pearls of Wisdom texts.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "prepare:docx": "tsx src/cli/prepareDocx.ts",
    "parse": "tsx src/cli/parse.ts",
    "parse:word": "tsx src/cli/parseWord.ts",
    "parse:file": "tsx src/cli/parse.ts --file",
    "pdf:profile": "tsx src/cli/profilePdfProcessing.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/cli/seed.ts",
    "generate:downloads": "tsx src/cli/generateDownloads.ts",
    "metadata:ai": "tsx src/cli/enrichMetadataWithAi.ts",
    "build": "prisma generate && tsc",
    "smoke": "tsx src/cli/smoke.ts",
    "start": "node dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "openai": "^6.37.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
