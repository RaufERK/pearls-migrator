generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "js"
}

generator webClient {
  provider               = "prisma-client"
  output                 = "../web/generated/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "postgresql"
}

model Pearl {
  slug         String          @id
  title        String
  siteLabel    String?
  siteRawLabel String?
  siteYear     Int
  siteMonth    Int?
  siteMonths   String[]        @default([])
  siteSortDate String
  documentsCount Int
  sourcePdf    String
  sourceWord   String?
  preparedDocx String?
  jsonPath     String
  pages        Int
  layout       String
  parsedAt     DateTime
  documents    PearlDocument[]

  @@index([siteSortDate])
  @@index([siteYear])
}

model PearlDocument {
  id              String   @id
  pearlSlug       String
  pearl           Pearl    @relation(fields: [pearlSlug], references: [slug], onDelete: Cascade)
  position        Int
  documentTitle   String?
  documentType    String
  description     String   @db.Text
  authorName      String?
  authorSlug      String?
  authorRaw       String?  @db.Text
  creationDate    DateTime?
  creationYear    Int?
  creationRaw     String?  @db.Text
  pearlVolume     Int?
  pearlIssue      String?
  pearlDate       DateTime?
  pearlRawDate    String?
  pearlRaw        String?  @db.Text
  header          Json     @default("[]")
  footer          Json     @default("[]")
  content         String   @db.Text
  paragraphsCount Int

  @@unique([pearlSlug, position])
  @@index([authorSlug])
  @@index([creationYear])
  @@index([documentType])
}
