<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{seo.title}}</title>
    <meta name="description" content="{{seo.description}}">
    <link rel="canonical" href="{{seo.canonicalUrl}}">
    <meta property="og:title" content="{{seo.title}}">
    <meta property="og:description" content="{{seo.description}}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{seo.canonicalUrl}}">
    <link rel="stylesheet" href="/static/styles.css">
  </head>
  <body>
    <main class="page">
      <section class="index">
        <header class="index__header">
          <h1>Жемчужины Мудрости</h1>
        </header>

        {{#if filters.hasActive}}
          <nav class="active-filters" aria-label="Активные фильтры">
            <span class="active-filters__label">Фильтр:</span>
            {{#each filters.active}}
              <a class="filter-chip filter-chip--active" href="{{href}}">{{label}} ×</a>
            {{/each}}
          </nav>
        {{/if}}

        <div class="index__list">
          {{#each documentGroups}}
            <section class="year-group" aria-labelledby="year-{{year}}">
              <h2 id="year-{{year}}">{{year}}</h2>
              {{#each months}}
                <section class="month-group" aria-label="{{label}}">
                  <div class="month-group__list">
                    {{#each documents}}
                      <article class="index-card">
                        <a class="index-card__main" href="{{path}}">
                          <span class="index-card__title">{{siteMonthLabel}}</span>
                        </a>
                        {{#if singleDocument}}
                          <section class="contained-documents contained-documents--single" aria-label="Материал внутри выпуска">
                            {{#if singleDocument.author}}
                              <span class="contained-documents__author">{{singleDocument.author}}</span>
                            {{/if}}
                            {{#if singleDocument.title}}
                              <span class="contained-documents__title">«{{singleDocument.title}}»</span>
                            {{else}}
                              <span class="contained-documents__title">{{singleDocument.rawHeader}}</span>
                            {{/if}}
                            {{#if singleDocument.partTitle}}
                              <span class="contained-documents__part">{{singleDocument.partTitle}}</span>
                            {{/if}}
                          </section>
                        {{else}}
                          {{#if documents}}
                            <section class="contained-documents" aria-label="Материалы внутри выпуска">
                              <ol class="contained-documents__list">
                                {{#each documents}}
                                  <li>
                                    {{#if author}}
                                      <span class="contained-documents__author">
                                        {{author}}{{#if creationDateLabel}} ({{creationDateLabel}}){{/if}}
                                      </span>
                                    {{/if}}
                                    {{#if title}}
                                      <span class="contained-documents__title">«{{title}}»</span>
                                    {{else}}
                                      <span class="contained-documents__title">{{rawHeader}}</span>
                                    {{/if}}
                                    {{#if partTitle}}
                                      <span class="contained-documents__part">{{partTitle}}</span>
                                    {{/if}}
                                  </li>
                                {{/each}}
                              </ol>
                            </section>
                          {{/if}}
                        {{/if}}
                        <nav class="download-links" aria-label="Скачать {{title}}">
                          <span class="download-links__label">Скачать:</span>
                          <a href="{{downloads.txt}}">TXT</a>
                          <a href="{{downloads.docx}}">DOCX</a>
                          <a href="{{downloads.epub}}">EPUB</a>
                        </nav>
                      </article>
                    {{/each}}
                  </div>
                </section>
              {{/each}}
            </section>
          {{else}}
            <p class="index__empty">По выбранным фильтрам документы не найдены.</p>
          {{/each}}
        </div>
      </section>
    </main>
  </body>
</html>
