<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{seo.title}}</title>
    <meta name="description" content="{{seo.description}}">
    <link rel="canonical" href="{{seo.canonicalUrl}}">
    <meta property="og:title" content="{{seo.title}}">
    <meta property="og:description" content="{{seo.description}}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{seo.canonicalUrl}}">
    <link rel="stylesheet" href="/static/styles.css">
  </head>
  <body>
    <main class="page">
      <section class="index">
        <header class="index__header">
          <h1>Жемчужины Мудрости</h1>
        </header>

        {{#if filters.hasActive}}
          <nav class="active-filters" aria-label="Активные фильтры">
            <span class="active-filters__label">Фильтр:</span>
            {{#each filters.active}}
              <a class="filter-chip filter-chip--active" href="{{href}}">{{label}} ×</a>
            {{/each}}
          </nav>
        {{/if}}

        <div class="index__list">
          {{#each documentGroups}}
            <section class="year-group" aria-labelledby="year-{{year}}">
              <h2 id="year-{{year}}">{{year}}</h2>
              {{#each months}}
                <section class="month-group" aria-label="{{label}}">
                  <div class="month-group__list">
                    {{#each documents}}
                      <article class="index-card" data-href="{{path}}" tabindex="0">
                        <a class="index-card__main" href="{{path}}">
                          <span class="index-card__title">{{siteMonthLabel}}</span>
                        </a>
                        {{#if singleDocument}}
                          <section class="contained-documents contained-documents--single" aria-label="Материал внутри выпуска">
                            {{#if singleDocument.documentTypeLabel}}
                              {{#if singleDocument.documentTypeLink}}
                                <a class="contained-documents__type contained-documents__link" href="{{singleDocument.documentTypeLink.href}}">{{singleDocument.documentTypeLabel}}</a>
                              {{else}}
                                <span class="contained-documents__type">{{singleDocument.documentTypeLabel}}</span>
                              {{/if}}
                            {{/if}}
                            {{#if singleDocument.author}}
                              {{#if singleDocument.authorLink}}
                                <a class="contained-documents__author contained-documents__link" href="{{singleDocument.authorLink.href}}">{{singleDocument.author}}</a>
                              {{else}}
                                <span class="contained-documents__author">{{singleDocument.author}}</span>
                              {{/if}}
                            {{/if}}
                            {{#if singleDocument.title}}
                              <span class="contained-documents__title">«{{singleDocument.title}}»</span>
                            {{else}}
                              <span class="contained-documents__title">{{singleDocument.rawHeader}}</span>
                            {{/if}}
                            {{#if singleDocument.creationLabel}}
                              {{#if singleDocument.creationYearLink}}
                                <a class="contained-documents__date contained-documents__link" href="{{singleDocument.creationYearLink.href}}">({{singleDocument.creationLabel}})</a>
                              {{else}}
                                <span class="contained-documents__date">({{singleDocument.creationLabel}})</span>
                              {{/if}}
                            {{/if}}
                            {{#if singleDocument.partTitle}}
                              <span class="contained-documents__part">{{singleDocument.partTitle}}</span>
                            {{/if}}
                          </section>
                        {{else}}
                          {{#if documents}}
                            <section class="contained-documents" aria-label="Материалы внутри выпуска">
                              <ol class="contained-documents__list">
                                {{#each documents}}
                                  <li>
                                    {{#if documentTypeLabel}}
                                      {{#if documentTypeLink}}
                                        <a class="contained-documents__type contained-documents__link" href="{{documentTypeLink.href}}">{{documentTypeLabel}}</a>
                                      {{else}}
                                        <span class="contained-documents__type">{{documentTypeLabel}}</span>
                                      {{/if}}
                                    {{/if}}
                                    <span class="contained-documents__meta">
                                      {{#if author}}
                                        {{#if authorLink}}
                                          <a class="contained-documents__author contained-documents__link" href="{{authorLink.href}}">{{author}}</a>
                                        {{else}}
                                          <span class="contained-documents__author">{{author}}</span>
                                        {{/if}}
                                      {{/if}}
                                    </span>
                                    {{#if title}}
                                      <span class="contained-documents__title">«{{title}}»</span>
                                    {{else}}
                                      <span class="contained-documents__title">{{rawHeader}}</span>
                                    {{/if}}
                                    {{#if creationLabel}}
                                      {{#if creationYearLink}}
                                        <a class="contained-documents__date contained-documents__link" href="{{creationYearLink.href}}">({{creationLabel}})</a>
                                      {{else}}
                                        <span class="contained-documents__date">({{creationLabel}})</span>
                                      {{/if}}
                                    {{/if}}
                                    {{#if partTitle}}
                                      <span class="contained-documents__part">{{partTitle}}</span>
                                    {{/if}}
                                  </li>
                                {{/each}}
                              </ol>
                            </section>
                          {{/if}}
                        {{/if}}
                        <nav class="download-links" aria-label="Скачать {{title}}">
                          <span class="download-links__label">Скачать:</span>
                          <a href="{{downloads.txt}}">TXT</a>
                          <a href="{{downloads.docx}}">DOCX</a>
                          <a href="{{downloads.epub}}">EPUB</a>
                        </nav>
                      </article>
                    {{/each}}
                  </div>
                </section>
              {{/each}}
            </section>
          {{else}}
            <p class="index__empty">По выбранным фильтрам документы не найдены.</p>
          {{/each}}
        </div>
      </section>
    </main>
    <script>
      for (const card of document.querySelectorAll('.index-card[data-href]')) {
        card.addEventListener('click', (event) => {
          if (event.target.closest('a, button, input, select, textarea')) {
            return;
          }

          window.location.href = card.dataset.href;
        });

        card.addEventListener('keydown', (event) => {
          if (event.target !== card || !['Enter', ' '].includes(event.key)) {
            return;
          }

          event.preventDefault();
          window.location.href = card.dataset.href;
        });
      }
    </script>
  </body>
</html>
