<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{seo.title}}</title>
    <meta name="description" content="{{seo.description}}">
    <link rel="canonical" href="{{seo.canonicalUrl}}">
    <meta property="og:title" content="{{seo.title}}">
    <meta property="og:description" content="{{seo.description}}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{seo.canonicalUrl}}">
    <link rel="stylesheet" href="/static/styles.css">
  </head>
  <body>
    <main class="page">
      <section class="index">
        <header class="index__header">
          <p>Каталог распарсенных PDF</p>
          <h1>Жемчужины Мудрости</h1>
        </header>

        <div class="index__list">
          {{#each documents}}
            <article class="index-card">
              <a class="index-card__main" href="{{path}}">
                <span class="index-card__title">{{title}}</span>
                <span class="index-card__subtitle">{{subtitle}}</span>
                <span class="index-card__meta">{{pages}} стр. · {{paragraphs}} абз. · {{layout}}</span>
              </a>
              <nav class="download-links" aria-label="Скачать {{title}}">
                <a href="{{downloads.txt}}">TXT</a>
                <a href="{{downloads.docx}}">DOCX</a>
                <a href="{{downloads.epub}}">EPUB</a>
              </nav>
            </article>
          {{/each}}
        </div>
      </section>
    </main>
  </body>
</html>
