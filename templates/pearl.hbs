<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{seo.title}}</title>
    <meta name="description" content="{{seo.description}}">
    <link rel="canonical" href="{{seo.canonicalUrl}}">
    <meta property="og:title" content="{{seo.title}}">
    <meta property="og:description" content="{{seo.description}}">
    <meta property="og:type" content="article">
    <meta property="og:url" content="{{seo.canonicalUrl}}">
    <link rel="stylesheet" href="/static/styles.css">
  </head>
  <body>
    <main class="page">
      <article class="pearl">
        <header class="pearl__header">
          <nav class="pearl__back" aria-label="Навигация">
            <a href="/">← Назад к списку</a>
          </nav>
          <nav class="download-links download-links--center" aria-label="Скачать лекцию">
            <span class="download-links__label">Скачать:</span>
            <a href="{{item.downloads.txt}}">TXT</a>
            <a href="{{item.downloads.docx}}">DOCX</a>
            <a href="{{item.downloads.epub}}">EPUB</a>
            <button class="download-links__button" type="button" onclick="window.print()">Печатать</button>
          </nav>
          <h1>{{document.title}}</h1>
          {{#if document.sitePublication.label}}
            <p>{{document.sitePublication.label}}</p>
          {{/if}}
        </header>

        {{#if original.showInsteadOfText}}
          <section class="pearl__body">
            <div class="original-pdf">
              <p>Этот материал лучше читать в исходном файле: <a href="{{original.href}}">{{original.label}}</a></p>
              {{#if original.notes}}
                <p>{{original.notes}}</p>
              {{/if}}
              <iframe class="original-pdf__frame" src="{{original.href}}" title="Исходный файл"></iframe>
            </div>
          </section>
        {{else}}
          <section class="pearl__body">
            {{#each displayDocuments}}
              <section class="inner-document">
                <header class="inner-document__header">
                  {{#each displayHeader}}
                    <p>{{this}}</p>
                  {{/each}}
                </header>
                <div class="inner-document__body">
                  {{#each parts.body}}
                    <p>{{text}}</p>
                  {{/each}}
                </div>
                {{#if parts.footer}}
                  <footer class="inner-document__footer">
                    {{#each parts.footer}}
                      <p>{{text}}</p>
                    {{/each}}
                  </footer>
                {{/if}}
              </section>
            {{/each}}
          </section>
        {{/if}}

        <footer class="pearl__footer">
          <span>Адрес страницы: <a href="{{seo.canonicalUrl}}">{{seo.canonicalUrl}}</a></span>
        </footer>
      </article>
    </main>
    {{#if print.auto}}
      <script>
        window.addEventListener('load', () => {
          window.print();
        });
      </script>
    {{/if}}
  </body>
</html>
